// Amethyst — Water Station Accounting & Management
// PostgreSQL + Prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  super_admin
  admin
  driver
}

enum ProductUnitType {
  bottle
  carton
  gallon
  coupon
}

enum VehicleLoadStatus {
  open
  closed
}

model User {
  id           String   @id @default(uuid())
  fullName     String   @map("full_name")
  phone        String   @unique
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  vehiclesAsDriver Vehicle[]      @relation("VehicleDriver")
  vehicleLoads     VehicleLoad[]
  stationSales     StationSale[]
  vehicleSales     VehicleSale[]
  expenses         Expense[]
  auditLogs        AuditLog[]
  loadsCreated     VehicleLoad[]  @relation("LoadCreatedBy")

  @@map("users")
}

model Vehicle {
  id            String   @id @default(uuid())
  vehicleNumber String   @unique @map("vehicle_number")
  driverId      String?  @map("driver_id")
  isActive      Boolean  @default(true) @map("is_active")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  driver       User?         @relation("VehicleDriver", fields: [driverId], references: [id])
  vehicleLoads VehicleLoad[]
  vehicleSales VehicleSale[]
  expenses     Expense[]

  @@index([driverId])
  @@map("vehicles")
}

model Product {
  id           String          @id @default(uuid())
  name         String
  unitType     ProductUnitType @map("unit_type")
  price        Decimal         @db.Decimal(12, 2)
  stationStock Int             @default(0) @map("station_stock")
  isActive     Boolean         @default(true) @map("is_active")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  vehicleLoads VehicleLoad[]
  stationSales StationSale[]
  vehicleSales VehicleSale[]

  @@map("products")
}

model VehicleLoad {
  id               String              @id @default(uuid())
  vehicleId        String              @map("vehicle_id")
  driverId         String              @map("driver_id")
  productId        String              @map("product_id")
  quantityLoaded   Int                 @map("quantity_loaded")
  quantityReturned Int                 @default(0) @map("quantity_returned")
  quantitySold     Int                 @default(0) @map("quantity_sold")
  loadDate         DateTime            @map("load_date") @db.Date
  status           VehicleLoadStatus   @default(open)
  createdById      String              @map("created_by_id")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])
  driver    User    @relation(fields: [driverId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
  createdBy User    @relation("LoadCreatedBy", fields: [createdById], references: [id])

  @@index([vehicleId, productId, status])
  @@index([driverId])
  @@index([loadDate])
  @@map("vehicle_loads")
}

model StationSale {
  id          String   @id @default(uuid())
  productId   String   @map("product_id")
  quantity    Int
  unitPrice   Decimal  @map("unit_price") @db.Decimal(12, 2)
  totalAmount Decimal  @map("total_amount") @db.Decimal(14, 2)
  soldById    String   @map("sold_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id])
  soldBy  User    @relation(fields: [soldById], references: [id])

  @@index([createdAt])
  @@index([productId])
  @@map("station_sales")
}

model VehicleSale {
  id          String   @id @default(uuid())
  vehicleId   String   @map("vehicle_id")
  driverId    String   @map("driver_id")
  productId   String   @map("product_id")
  quantity    Int
  unitPrice   Decimal  @map("unit_price") @db.Decimal(12, 2)
  totalAmount Decimal  @map("total_amount") @db.Decimal(14, 2)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  driver  User    @relation(fields: [driverId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([vehicleId, driverId])
  @@index([createdAt])
  @@map("vehicle_sales")
}

model Expense {
  id        String   @id @default(uuid())
  driverId  String?  @map("driver_id")
  vehicleId String?  @map("vehicle_id")
  amount    Decimal  @db.Decimal(12, 2)
  note      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  driver  User?    @relation(fields: [driverId], references: [id])
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])

  @@index([driverId])
  @@index([createdAt])
  @@map("expenses")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  details    Json?
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
