# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/amethyst?schema=public"

# Server
NODE_ENV=development
PORT=4000

# JWT
JWT_SECRET="replace-with-a-long-random-string"
JWT_EXPIRES_IN=7d

# Password hashing
BCRYPT_ROUNDS=12

# CORS: comma-separated origins, or * for all (dev only)
CORS_ORIGIN=*
